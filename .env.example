# ---------------------------------------------------------------------------
# OtakuFusion — Environment variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# ---------------------------------------------------------------------------

# API
NEXT_PUBLIC_API_URL=
# Maruno / Miruro Native (епізоди + стрім); якщо порожньо — використовується NEXT_PUBLIC_API_URL
NEXT_PUBLIC_STREAM_API_URL=
# Опційно: явний хост лише для GET /api/watch/resolve (проксі в Next). Інакше порядок:
# NEXT_PUBLIC_ANIMEKAI_API_URL → NEXT_PUBLIC_STREAM_API_URL → NEXT_PUBLIC_API_URL
# База без подвійного /api: корінь https://xxx.vercel.app або вже .../api
WATCH_RESOLVE_UPSTREAM_URL=

# AnimeKai REST API (епізоди / сервери / source); за замовчуванням https://animekai.fly.dev
NEXT_PUBLIC_ANIMEKAI_API_URL=
# AniLiberty / Anilibria API v1 (match + stream). За замовчуванням https://anilibria.top/api/v1
# ANILIBRIA_API_BASE_URL=
# Ручний мапінг AniList id → alias релізу на AniLiberty, якщо пошук API не знаходить тайтл (JSON-об'єкт, один рядок або багаторядковий)
# ANILIBRIA_ANILIST_ALIAS_JSON={"16498":"your-release-alias"}
# (optional, server-side override for internal proxy)
ANIMEKAI_API_URL=
# Secret for protected AnimeKai mapping endpoints (/api/mapping/*)
MAPPING_ADMIN_SECRET=
# true — спочатку прямий резолв на AnimeKai: GET .../api/anime/anilist/{id}, якщо 404 — GET .../api/anime/mal/{mal_id} (idMal з AniList); інакше пошук за назвою
NEXT_PUBLIC_ANIMEKAI_ANILIST_RESOLVE=

# Site (optional; used for metadata, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://otakufusion.com

# Database
MONGODB_URI=

# JWT — Auth (use the same secrets in both pairs for consistency)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
NEXT_JWT_ACCESS_SECRET=
NEXT_JWT_REFRESH_SECRET=

# Video proxy (optional; for HLS / M3U8 if your player needs a proxy)
NEXT_PUBLIC_PROXY_URL=
# HLS: за замовчуванням same-origin /api/m3u8-proxy. Зовнішній: .../m3u8-proxy?url= | без проксі: direct
# (У коді плеєра змінні читаються лише як process.env.NEXT_PUBLIC_… — так Next інлайнить їх у клієнт.)
NEXT_PUBLIC_M3U8_PROXY_URL=
# Якщо локально HLS дає 403 після кількох секунд, а на Vercel — ні: CDN часто різниться до IP (домашній vs датацентр).
# Обхід: у .env.local вкажіть проксі деплою, напр. NEXT_PUBLIC_M3U8_PROXY_URL=https://<ваш-проєкт>.vercel.app/api/m3u8-proxy?url=
# CORS: для http://localhost та http://127.0.0.1 (будь-який порт) заголовки додаються автоматично; для інших origin:
# M3U8_PROXY_CORS_ALLOWED_ORIGINS=https://preview-xxx.vercel.app,https://staging.example.com
M3U8_PROXY_CORS_ALLOWED_ORIGINS=

# Watch resolve — серверний HLS probe через /api/m3u8-proxy (GET /api/watch/resolve)
# WATCH_PROBE_SKIP_VARIANT: не задано — для lang=dub пропускається перевірка variant (швидше); для sub — variant перевіряється.
# Явно: 1|true — skip variant для всіх; 0|false — повний probe для всіх.
# WATCH_PROBE_MASTER_MS / WATCH_PROBE_VARIANT_MS — таймаути fetch (мс), діапазон 1200–45000.
# WATCH_PROBE_SKIP_VARIANT=
# WATCH_PROBE_MASTER_MS=
# WATCH_PROBE_VARIANT_MS=

# Кеш успішного GET /api/watch/resolve (Next unstable_cache). У dev увімкнути: WATCH_RESOLVE_CACHE=1. Вимкнути скрізь: WATCH_RESOLVE_CACHE=0
# WATCH_RESOLVE_CACHE=
# WATCH_RESOLVE_CACHE_SECONDS=30
# Прямий HLS у плеєрі (без /api/m3u8-proxy) для hostname за суфіксами (через кому). Додається до вбудованих AniLibria (*.libria.fun, anilibria.*). Megaup: лише через цю змінну і лише якщо CDN приймає ваш origin (на localhost прямий Megaup часто дає 403 без Referer megaup.live — лишайте проксі).
# NEXT_PUBLIC_HLS_DIRECT_HOST_SUFFIXES=

# Email (SMTP) — verification, password reset, etc.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Cloudinary — user avatar uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Next.js Image (optional)
# NEXT_IMAGE_OPTIMIZE_IN_DEV=true — увімкнути оптимізацію в `next dev` (за замовчуванням у dev вона вимкнена, щоб уникнути багу LRU-кешу в окремих версіях Next 16)
# NEXT_IMAGE_UNOPTIMIZED=true — без оптимізації скрізь (зокрема production)
