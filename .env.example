# =============================================================================
# OtakuFusion — Environment Variables
#
# Vercel: Project → Settings → Environment Variables
#   • Required block → Production (+ Preview if you test previews)
#   • Optional → only features you enable
#
# Local: copy to `.env.local` (never commit real secrets)
# =============================================================================

# ── Required ────────────────────────────────────────────────────────────────
# Auth & database
MONGODB_URI=
NEXT_JWT_ACCESS_SECRET=
NEXT_JWT_REFRESH_SECRET=

# Transactional email (signup / password reset)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Playback — Crysoline (Anilibria catalog & resolve)
# https://docs.crysoline.moe/
CRYSOLINE_API_KEY=

# ── Recommended on Vercel ───────────────────────────────────────────────────
# Canonical URL for metadata, OG tags, server-side resolve probes.
# On Vercel you can omit this — app falls back to VERCEL_URL when unset.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── Optional: TVDB (home / watch hero clear logos & fanart) ─────────────────
# TVDB_API_KEY=

# ── Optional: Cloudinary (profile avatar upload — all three together) ─────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Anikoto provider (server-only BFF — Japanese / English sub & dub) ─
# Must expose /api/search, /api/info, /api/episodes/:id, /api/stream
# Working example: https://anikoto-api-nine.vercel.app
# ANIKOTO_API_BASE=https://anikoto-api-nine.vercel.app
# ANIKOTO_FETCH_TIMEOUT_MS=28000

# ── Optional: Hikka provider (relay when server IP is blocked) ────────────────
# HIKKA_FEATURES_RELAY_BASE=https://your-worker.workers.dev
# HIKKA_FEATURES_API_BASE=https://api.hikka-features.pp.ua

# ── Optional: streaming / resolve tuning (defaults are OK on Vercel) ────────
# Faster watch resolve — skip variant playlist probe (recommended: 1)
WATCH_PROBE_SKIP_VARIANT=1

# Comma-separated CDN host suffixes for direct browser HLS (skip /api/m3u8-proxy).
# Example: proxy.crysoline.moe,crysoline.moe
# NEXT_PUBLIC_HLS_DIRECT_HOST_SUFFIXES=

# Optional: Cloudflare Worker HLS relay (edge passthrough for Anikoto disguised segments).
# Deploy workers/hls-relay — then set to https://<your-worker>.workers.dev
# NEXT_PUBLIC_M3U8_PROXY_BASE=

# CRYSOLINE_API_BASE_URL=https://api.crysoline.moe
# CRYSOLINE_FETCH_TIMEOUT_MS=28000
# CRYSOLINE_429_MAX_WAIT_MS=12000
# WATCH_PROBE_MASTER_MS=4000
# WATCH_PROBE_VARIANT_MS=3000
# WATCH_RESOLVE_MAX_PROBE_CANDIDATES=3
# WATCH_RESOLVE_CACHE=1
# WATCH_RESOLVE_CACHE_SECONDS=30

# ── Local dev only (do not set on Vercel) ───────────────────────────────────
# NEXT_IMAGE_OPTIMIZE_IN_DEV=true
# NEXT_IMAGE_UNOPTIMIZED=true
# NEXT_PUBLIC_PLAYER_DEFER_STRICT_INIT=0
