# ---------------------------------------------------------------------------
# OtakuFusion — Environment variables
# Copy this file to `.env` and fill in your values. Never commit `.env` to git.
# ---------------------------------------------------------------------------

# Опційно: окремий публічний базовий URL стрім-API (якщо порожньо — same-origin цього Next-додатку).
NEXT_PUBLIC_STREAM_API_URL=
# Опційно: явний хост лише для GET /api/watch/resolve (проксі в Next).
# База без подвійного /api: корінь https://xxx.vercel.app або вже .../api
WATCH_RESOLVE_UPSTREAM_URL=

# Crysoline (Animepahe): серверний ключ для /api/v1/anime/animepahe/* (обов'язково для перегляду)
CRYSOLINE_API_KEY=
# CRYSOLINE_API_BASE_URL=https://api.crysoline.moe
# За жорсткого rate limit: вимкнути один запит sources (dub-probe) у POST /api/animepahe/catalog — дуб у списку епізодів не підсвітиться до наступного «свіжого» каталогу
# Найшвидший catalog — без dub-probe на серії:
# ANIMEPAHE_SKIP_SERIES_DUB_PROBE=1
# ANIMEPAHE_DUB_PROBE_TIMEOUT_MS=4500 — ліміт dub-probe (мс), якщо probe увімкнено.
# CRYSOLINE_429_MAX_WAIT_MS=12000 — макс. пауза після 429 (за замовч. 12 с, раніше до 90 с).

# Miruno Native API (server): gap-fill dub, коли в каталозі Animepahe для епізоду немає `hasDub: true`.
# Base URL without trailing slash (e.g. https://miruno-api.vercel.app). Потрібен `anilist_id` у watch/resolve.
# UI English для таких епізодів за замовчуванням увімкнено; вимкнути: NEXT_PUBLIC_MIRUNO_DUB_FALLBACK=0
# MIRUNO_API_BASE_URL=
# MIRUNO_DUB_HLS_MANIFEST_CHECK=1 — увімкнути евристику master.m3u8 (TYPE=AUDIO / EN) для Miruno dub; за замовчуванням вимкнено (багато хибних відсівок)

# Site (рекомендовано для SSR fetch і canonical): canonical URL без слешу в кінці
NEXT_PUBLIC_SITE_URL=https://otakufusion.com

# Database
MONGODB_URI=

# JWT — Auth (use the same secrets in both pairs for consistency)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
NEXT_JWT_ACCESS_SECRET=
NEXT_JWT_REFRESH_SECRET=

# Video proxy (optional; for HLS / M3U8 if your player needs a proxy)
NEXT_PUBLIC_PROXY_URL=
# HLS: за замовчуванням same-origin `/api/m3u8-proxy` (`?url=` + `&headers=`).
# Публічний **DeveloperJosh m3u8-proxy** (m3u8proxy.fly.dev тощо): достатньо `NEXT_PUBLIC_M3U8_PROXY_URL=https://m3u8proxy.fly.dev` — додаються `/fetch/?url=` та `&ref=` (Referer), без `headers`.
# На **localhost** / **127.0.0.1** при `*.fly.dev` у цій змінній автоматично використовується same-origin `/api/m3u8-proxy` (публічний Fly часто 404/403).
# Власний деплой у стилі Next: `NEXT_PUBLIC_M3U8_PROXY_URL=https://<проєкт>.vercel.app/api/m3u8-proxy?url=`
NEXT_PUBLIC_M3U8_PROXY_URL=
# Якщо локально HLS дає 403 після кількох секунд, а на Vercel — ні: CDN часто різниться до IP (домашній vs датацентр).
# Обхід: у .env.local вкажіть проксі деплою, напр. NEXT_PUBLIC_M3U8_PROXY_URL=https://<ваш-проєкт>.vercel.app/api/m3u8-proxy?url=
# CORS: для http://localhost та http://127.0.0.1 (будь-який порт) заголовки додаються автоматично; для інших origin:
# M3U8_PROXY_CORS_ALLOWED_ORIGINS=https://preview-xxx.vercel.app,https://staging.example.com
M3U8_PROXY_CORS_ALLOWED_ORIGINS=

# Watch resolve — серверний HLS probe тим самим проксі, що й плеєр (`NEXT_PUBLIC_M3U8_PROXY_URL` або `/api/m3u8-proxy`).
# WATCH_PROBE_SKIP_VARIANT: не задано — для lang=dub пропускається перевірка variant (швидше); для sub — variant перевіряється.
# Явно: 1|true — skip variant для всіх; 0|false — повний probe для всіх.
# WATCH_PROBE_MASTER_MS / WATCH_PROBE_VARIANT_MS — таймаути fetch (мс), діапазон 1200–45000.
# WATCH_PROBE_SKIP_VARIANT=
# WATCH_PROBE_MASTER_MS=
# WATCH_PROBE_VARIANT_MS=
# Макс. HLS-кандидатів для probe на resolve (за роздільністю). Dub за замовч. 3.
# WATCH_RESOLVE_MAX_PROBE_CANDIDATES=3
# OP/ED маркери з Anilibria під час resolve (2+ запити Crysoline). За замовч. вимкнено — швидший старт.
# WATCH_RESOLVE_FETCH_SEGMENT_HINTS=1

# Кеш успішного GET /api/watch/resolve (Next unstable_cache). У dev увімкнути: WATCH_RESOLVE_CACHE=1. Вимкнути скрізь: WATCH_RESOLVE_CACHE=0
# WATCH_RESOLVE_CACHE=
# WATCH_RESOLVE_CACHE_SECONDS=30
# Прямий HLS у плеєрі (без /api/m3u8-proxy) для hostname за суфіксами (через кому). Megaup: лише через цю змінну і лише якщо CDN приймає ваш origin (на localhost прямий Megaup часто дає 403 без Referer megaup.live — лишайте проксі).
# NEXT_PUBLIC_HLS_DIRECT_HOST_SUFFIXES=
# Плеєр (dev): за замовчуванням відкладений init Hls увімкнено (менше bufferAddCodec на Strict Mode). Вимкнути: NEXT_PUBLIC_PLAYER_DEFER_STRICT_INIT=0 або false
# NEXT_PUBLIC_PLAYER_DEFER_STRICT_INIT=

# Email (SMTP) — verification, password reset, etc.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cloudinary — user avatar uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Next.js Image (optional)
# NEXT_IMAGE_OPTIMIZE_IN_DEV=true — увімкнути оптимізацію в `next dev` (за замовчуванням у dev вона вимкнена, щоб уникнути багу LRU-кешу в окремих версіях Next 16)
# NEXT_IMAGE_UNOPTIMIZED=true — без оптимізації скрізь (зокрема production)
