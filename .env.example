# =============================================================================
# OtakuFusion — copy to `.env.local` (local dev) or set in your host dashboard.
# Never commit real secrets.
# =============================================================================

# --- Required: auth & database ---
MONGODB_URI=
NEXT_JWT_ACCESS_SECRET=
NEXT_JWT_REFRESH_SECRET=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Required: playback (Crysoline — Animepahe + Anilibria) ---
# https://docs.crysoline.moe/
CRYSOLINE_API_KEY=

# --- Recommended ---
NEXT_PUBLIC_SITE_URL=

# --- Optional: Crysoline ---
# CRYSOLINE_API_BASE_URL=https://api.crysoline.moe
# CRYSOLINE_FETCH_TIMEOUT_MS=28000
# CRYSOLINE_429_MAX_WAIT_MS=12000

# --- Optional: streaming / resolve ---
NEXT_PUBLIC_HLS_DIRECT_HOST_SUFFIXES=
WATCH_PROBE_SKIP_VARIANT=1
# WATCH_PROBE_MASTER_MS=
# WATCH_PROBE_VARIANT_MS=
# WATCH_RESOLVE_MAX_PROBE_CANDIDATES=3
# WATCH_RESOLVE_CACHE=1
# WATCH_RESOLVE_CACHE_SECONDS=30
# WATCH_RESOLVE_FETCH_SEGMENT_HINTS=1
# ANIMEPAHE_DUB_PROBE_TIMEOUT_MS=4500
# ANIMEPAHE_SKIP_SERIES_DUB_PROBE=1

# --- Optional: Miruno English dub gap-fill (Animepahe) ---
MIRUNO_API_BASE_URL=
MIRUNO_DUB_HLS_MANIFEST_CHECK=1

# --- Optional: Hikka provider (often needs relay on Vercel) ---
HIKKA_FEATURES_RELAY_BASE=
# HIKKA_FEATURES_API_BASE=https://api.hikka-features.pp.ua

# --- Optional: home hero clear logos ---
TVDB_API_KEY=

# --- Optional: profile avatars ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Optional: Next.js images ---
# NEXT_IMAGE_OPTIMIZE_IN_DEV=true
# NEXT_IMAGE_UNOPTIMIZED=true

# --- Optional: player (dev) ---
# NEXT_PUBLIC_PLAYER_DEFER_STRICT_INIT=0
